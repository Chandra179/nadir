# ── Service addresses ──────────────────────────────────────────────────────────
# Override config.yaml values. All are optional if defaults match your setup.

# Qdrant gRPC addr (default: qdrant:6334 in Docker, localhost:6334 locally)
QDRANT_ADDR=qdrant:6334

# Qdrant collection name
QDRANT_COLLECTION=pkb_chunks

# Ollama base URL (default: http://host.docker.internal:11434 in Docker)
OLLAMA_ADDR=http://host.docker.internal:11434

# SPLADE sidecar (required only if sparse_scorer.provider: splade)
SPLADE_ADDR=http://splade:5001

# Reranker sidecar (required only if reranker.enabled: true)
RERANKER_ADDR=http://reranker:5002

# ── Logging ────────────────────────────────────────────────────────────────────
# dev = verbose structured logs; prod = JSON, errors only
LOGGER_LEVEL=prod

# ── Knowledge base ─────────────────────────────────────────────────────────────
# Path to markdown directory (default: gitbook)
NOTES_PATH=gitbook

# ── Embedder ───────────────────────────────────────────────────────────────────
# API key for non-Ollama embedding providers (e.g. OpenAI). Leave unset for Ollama.
# EMBEDDER_API_KEY=

# ── Feature flags ──────────────────────────────────────────────────────────────
# Override yaml booleans without editing config file
RERANKER_ENABLED=true
HYDE_ENABLED=true

# HyDE LLM model override
# HYDE_MODEL=gemma3:1b

# Semantic cache similarity cutoff (0.0–1.0); higher = stricter
# SEMANTIC_CACHE_THRESHOLD=0.90

# ── Grafana ────────────────────────────────────────────────────────────────────
# Grafana login credentials (default: admin/admin — CHANGE IN PROD)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin  # CHANGE THIS in prod

# ── Production / scaling ───────────────────────────────────────────────────────
# Tier 1 (single box): leave defaults above
# Tier 2+ (separate ML machine): update SPLADE_ADDR, RERANKER_ADDR, OLLAMA_ADDR
#   to point at ML machine IP, e.g.:
#   SPLADE_ADDR=http://10.0.0.2:5001
#   RERANKER_ADDR=http://10.0.0.2:5002
#   OLLAMA_ADDR=http://10.0.0.2:11434

# Prometheus retention (default 15d — increase for prod)
PROMETHEUS_RETENTION=30d

# Qdrant snapshot target dir (mounted volume path inside container)
QDRANT_SNAPSHOT_DIR=/qdrant/snapshots

# ── Eval ───────────────────────────────────────────────────────────────────────
# Only needed when running eval tool (cmd/eval). Not part of production binary.
EVAL_LLM_BASE_URL=http://localhost:11434/v1
EVAL_LLM_MODEL=llama3.1:8b-instruct-q4_K_M
EVAL_HISTORY_PATH=eval_history.jsonl
