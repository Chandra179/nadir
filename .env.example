# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# Prometheus retention
PROMETHEUS_RETENTION=30d

# --- App config overrides (config/config.go applyEnv) ---

# Knowledge base
NOTES_PATH=gitbook

# Qdrant
QDRANT_ADDR=localhost:6334
QDRANT_COLLECTION=pkb_chunks

# Embedder
OLLAMA_ADDR=http://localhost:11434
EMBEDDER_API_KEY=

# Sparse scorer (splade)
SPLADE_ADDR=http://localhost:5001

# Reranker
RERANKER_ADDR=http://localhost:5002
RERANKER_ENABLED=true

# Logging
LOGGER_LEVEL=dev

# HyDE
HYDE_ENABLED=false
HYDE_MODEL=gemma3:1b

# Semantic cache
SEMANTIC_CACHE_THRESHOLD=0.90

# Eval
EVAL_LLM_BASE_URL=http://localhost:11434/v1
EVAL_LLM_MODEL=llama3.1:8b-instruct-q4_K_M
EVAL_HISTORY_PATH=eval_history.jsonl
